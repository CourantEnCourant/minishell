#include <assert.h>
#include <string.h>
#include <unistd.h>
#include "libft.h"
#include "datastructures.h"
#include "gc_libft.h"
#include "minishell.h"

void	repr_token(void *token);

static void	test_t_token_case(t_gc *gc, char *s, char *expected_value,
		t_token_type expected_type)
{
	t_token	*token;

	ft_printf("Testing %s\n", s);
	token = init_token(s, gc);
	if (expected_value != NULL)
		assert(strcmp(token->value, expected_value) == 0);
	assert(token->type == expected_type);
	token->repr(token);
	ft_printf("\n");
}

static void	test_t_token(t_gc *gc)
{
	ft_printf("==========TEST_T_CMD==========\n");

	// operand
	test_t_token_case(gc, "ls -l", "ls -l", OPERAND);
	test_t_token_case(gc, "echo hello world", "echo hello world", OPERAND);
	test_t_token_case(gc, "", "", OPERAND);

	// pipe operator
	test_t_token_case(gc, "|", "|", PIPE);

	// and operator
	test_t_token_case(gc, "&&", "&&", AND);

	// or operator
	test_t_token_case(gc, "||", "||", OR);

	// subshell open
	test_t_token_case(gc, "(", "(", SUBSHELL);

	// subshell close
	test_t_token_case(gc, ")", ")", CLOSE_PAREN);

	// edge cases: similar but not operators
	test_t_token_case(gc, "&", NULL, OPERAND);
	test_t_token_case(gc, "|||", NULL, OPERAND);
	test_t_token_case(gc, "&&&", NULL, OPERAND);
	test_t_token_case(gc, "()", NULL, OPERAND);

	ft_printf("==========ALL TESTS PASSED==========\n\n");
}

static void	test_parser_tokenize_case(t_parser *parser, t_gc *gc, char *s)
{
	t_darray	*cmds;

	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_token);
	ft_printf("\n");
}

static void	test_parser_tokenize(t_gc *gc)
{
	t_parser	*parser;

	ft_printf("==========TEST_PARSER_TOKENIZE==========\n");
	parser = init_parser(gc);

	// empty string
	test_parser_tokenize_case(parser, gc, "");

	// single pipe
	test_parser_tokenize_case(parser, gc, "ls -l | grep -la");

	// pipe without spaces
	test_parser_tokenize_case(parser, gc, "ls -l|grep -la");

	// pipe + and
	test_parser_tokenize_case(parser, gc, "ls -l | grep -la && cat -e");

	// and without spaces
	test_parser_tokenize_case(parser, gc, "ls -l | grep -la&&cat -e");

	// pipe + and + or
	test_parser_tokenize_case(parser, gc, "ls -l | grep -la && cat -e || ls -la");

	// or without spaces
	test_parser_tokenize_case(parser, gc, "ls -l | grep -la&&cat -e|| ls -la");

	// operators inside double quotes (should not tokenize)
	test_parser_tokenize_case(parser, gc, "ls -l | \"grep -la&&cat -e\"|| ls -la");

	// operators inside single quotes (should not tokenize)
	test_parser_tokenize_case(parser, gc, "echo '|| && |' | cat");

	// parentheses
	test_parser_tokenize_case(parser, gc, "(echo hello && echo world)");

	// nested parentheses
	test_parser_tokenize_case(parser, gc, "(echo hello && (echo world || echo foo))");

	// parentheses without spaces
	test_parser_tokenize_case(parser, gc, "(ls -l)&&(echo hello)");

	// parentheses inside quotes (should not tokenize)
	test_parser_tokenize_case(parser, gc, "echo \"(hello)\" | cat");

	// simple command, no operators
	test_parser_tokenize_case(parser, gc, "echo hello world");

	// multiple pipes
	test_parser_tokenize_case(parser, gc, "cat file | grep foo | wc -l");

	// all operators combined
	test_parser_tokenize_case(parser, gc, "(ls | grep foo) && echo yes || echo no");

	ft_printf("==========ALL TESTS PASSED==========\n\n");
}

static void	test_parser_is_valid_case(t_parser *parser, char *s, bool expected)
{
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == expected);
}

static void	test_parser_is_valid_cmd(t_gc *gc)
{
	t_parser	*parser;

	ft_printf("==========TEST_PARSER_IS_VALID_CMD==========\n");
	parser = init_parser(gc);

	// basic
	test_parser_is_valid_case(parser, "", true);
	test_parser_is_valid_case(parser, "echo hello", true);

	// single quotes
	test_parser_is_valid_case(parser, "'hello'", true);
	test_parser_is_valid_case(parser, "''", true);
	test_parser_is_valid_case(parser, "'", false);
	test_parser_is_valid_case(parser, "'hello", false);

	// double quotes
	test_parser_is_valid_case(parser, "\"hello\"", true);
	test_parser_is_valid_case(parser, "\"\"", true);
	test_parser_is_valid_case(parser, "\"", false);
	test_parser_is_valid_case(parser, "\"hello", false);

	// mixed quotes
	test_parser_is_valid_case(parser, "\"'\"", true);
	test_parser_is_valid_case(parser, "'\"'", true);
	test_parser_is_valid_case(parser, "\"''\"", true);
	test_parser_is_valid_case(parser, "'\"\"'", true);
	test_parser_is_valid_case(parser, "\"'", false);
	test_parser_is_valid_case(parser, "'\"", false);
	test_parser_is_valid_case(parser, "\"'\"''", true);
	test_parser_is_valid_case(parser, "'\"'\"'\"", true);

	// parentheses
	test_parser_is_valid_case(parser, "()", true);
	test_parser_is_valid_case(parser, "(())", true);
	test_parser_is_valid_case(parser, "()()", true);
	test_parser_is_valid_case(parser, "((()))", true);
	test_parser_is_valid_case(parser, "(", false);
	test_parser_is_valid_case(parser, ")", false);
	test_parser_is_valid_case(parser, "((", false);
	test_parser_is_valid_case(parser, "))", false);
	test_parser_is_valid_case(parser, ")(", false);
	test_parser_is_valid_case(parser, "(()", false);
	test_parser_is_valid_case(parser, "())", false);

	// parentheses inside quotes (should be ignored)
	test_parser_is_valid_case(parser, "'()'", true);
	test_parser_is_valid_case(parser, "'('", true);
	test_parser_is_valid_case(parser, "')'", true);
	test_parser_is_valid_case(parser, "\"()\"", true);
	test_parser_is_valid_case(parser, "\"(\"", true);
	test_parser_is_valid_case(parser, "\")\"", true);

	// quotes inside parentheses
	test_parser_is_valid_case(parser, "('hello')", true);
	test_parser_is_valid_case(parser, "(\"hello\")", true);

	// combined edge cases
	test_parser_is_valid_case(parser, "''()()", true);
	test_parser_is_valid_case(parser, "(\")\"", false);
	test_parser_is_valid_case(parser, "(')'", false);
	test_parser_is_valid_case(parser, "\"(\")", false);
	test_parser_is_valid_case(parser, "'(')", false);

	// realistic commands
	test_parser_is_valid_case(parser, "(echo hello && echo world)", true);
	test_parser_is_valid_case(parser, "(echo hello && (echo world))", true);
	test_parser_is_valid_case(parser, "echo 'unclosed", false);
	test_parser_is_valid_case(parser, "echo \"unclosed", false);

	ft_printf("==========ALL TESTS PASSED==========\n\n");
}

static void	test_parser_parse_case(t_parser *parser, t_gc *gc, char *s,
		bool expected)
{
	t_darray	*tokens;
	t_btree		*ast;

	ft_printf("Testing %s\n", s);
	tokens = parser->tokenize(s, gc);
	ast = parser->parse(tokens);
	ast->repr(ast, repr_token);
	assert(parser->is_valid_tree(ast) == expected);
	ft_printf("\n");
}

void	test_parser_parse(t_gc *gc)
{
	t_parser	*parser;

	ft_printf("==========TEST_PARSER_PARSE==========\n");
	parser = init_parser(gc);

	test_parser_parse_case(parser, gc, "ls -l", true);
	test_parser_parse_case(parser, gc, "ls -l && grep something", true);
	test_parser_parse_case(parser, gc, "expr1 && expr2 || expr3 | expr4", true);
	test_parser_parse_case(parser, gc, "a | b && c || d", true);
	test_parser_parse_case(parser, gc, "a | b | c && d | e || f && g", true);

	// Invalid trees
	test_parser_parse_case(parser, gc, "ls |", false);
	test_parser_parse_case(parser, gc, "|| | && echo hello", false);

	// operator at the beginning
	test_parser_parse_case(parser, gc, "&& ls", false);
	test_parser_parse_case(parser, gc, "| ls", false);
	test_parser_parse_case(parser, gc, "|| ls", false);

	// operator at the end
	test_parser_parse_case(parser, gc, "ls &&", false);
	test_parser_parse_case(parser, gc, "ls ||", false);

	// consecutive operators
	test_parser_parse_case(parser, gc, "ls && || echo hi", false);
	test_parser_parse_case(parser, gc, "ls | | echo hi", false);
	test_parser_parse_case(parser, gc, "ls || && echo hi", false);

	// only operators
	test_parser_parse_case(parser, gc, "|", false);
	test_parser_parse_case(parser, gc, "&&", false);
	test_parser_parse_case(parser, gc, "||", false);

	// parentheses - valid
	test_parser_parse_case(parser, gc, "(a)", true);
	test_parser_parse_case(parser, gc, "(a && b)", true);
	test_parser_parse_case(parser, gc, "(a) && b", true);
	test_parser_parse_case(parser, gc, "a && (b)", true);
	test_parser_parse_case(parser, gc, "(a) && (b)", true);
	test_parser_parse_case(parser, gc, "a || (b && c)", true);
	test_parser_parse_case(parser, gc, "(a | b) && c", true);
	test_parser_parse_case(parser, gc, "(a && (b || c))", true);
	test_parser_parse_case(parser, gc, "((a || b) && (c || d))", true);
	test_parser_parse_case(parser, gc, "a && (b | c) || d", true);
	test_parser_parse_case(parser, gc, "(ls -l | grep foo) && echo yes || echo no", true);

	// parentheses - invalid

	// empty subshell
	test_parser_parse_case(parser, gc, "()", false);

	// subshell with only an operator inside
	test_parser_parse_case(parser, gc, "(|)", false);
	test_parser_parse_case(parser, gc, "(&&)", false);

	// operator before subshell (no left operand)
	test_parser_parse_case(parser, gc, "&& (a)", false);
	test_parser_parse_case(parser, gc, "| (a)", false);
	test_parser_parse_case(parser, gc, "|| (a)", false);

	// operator after subshell with nothing following
	test_parser_parse_case(parser, gc, "(a) &&", false);
	test_parser_parse_case(parser, gc, "(a) |", false);
	test_parser_parse_case(parser, gc, "(a) ||", false);

	// consecutive operators inside subshell
	test_parser_parse_case(parser, gc, "(a && || b)", false);
	test_parser_parse_case(parser, gc, "(a | | b)", false);

	// operator at start inside subshell
	test_parser_parse_case(parser, gc, "(| a)", false);
	test_parser_parse_case(parser, gc, "(&& a)", false);

	// operator at end inside subshell
	test_parser_parse_case(parser, gc, "(a |)", false);
	test_parser_parse_case(parser, gc, "(a &&)", false);

	// nested empty subshell
	test_parser_parse_case(parser, gc, "(())", false);

	// subshell with command on right side (invalid: subshell cannot have right child)
	test_parser_parse_case(parser, gc, "(a) b", false);

	ft_printf("==========ALL TESTS PASSED==========\n\n");
}


static void	test_exec_case(t_exec *exec, t_gc *gc, char *cmd)
{
	t_parser	*parser;
	t_btree		*ast;

	ft_printf("Testing exec: %s\n", cmd);
	parser = init_parser(gc);
	ast = parser->parse(parser->tokenize(cmd, gc));
	exec->execute(ast);
	ft_printf("\n");
}

static void	test_exec(t_gc *gc)
{
	t_exec	*exec;

	ft_printf("==========TEST_EXEC==========\n");

	// test single cmd
	exec = init_exec(gc);
	test_exec_case(exec, gc, "echo hello");
	test_exec_case(exec, gc, "echo hello world");
	test_exec_case(exec, gc, "echo -n hello");
	test_exec_case(exec, gc, "ls -l");
	test_exec_case(exec, gc, "/bin/echo bonjour");


	// test &&
	test_exec_case(exec, gc, "ls -l && echo success");

	// test ||
	test_exec_case(exec, gc, "ls -l || echo wrong");
	test_exec_case(exec, gc, "invalid || echo wrong");

	// test |
	test_exec_case(exec, gc, "echo hello | cat -e | cat -e");

	// test && || | combined (no parentheses)
	test_exec_case(exec, gc, "echo hello | cat -e && echo done");
	test_exec_case(exec, gc, "ls nonexistent && echo yes || echo no");
	test_exec_case(exec, gc, "echo start && echo hello | cat -e");
	test_exec_case(exec, gc,
		"ls nonexistent || echo b && echo c | cat -e");

	ft_printf("==========ALL TESTS PASSED==========\n\n");
}


t_darray	*flatten(t_btree *ast);
static void	test_flatten_case(char *cmd, t_parser *parser, t_gc *gc)
{
	t_darray	*tokens;
	t_btree		*ast;
	t_darray	*flattened;

	ft_printf("Testing %s\n", cmd);
	tokens = parser->tokenize(cmd, gc);
	ast = parser->parse(tokens);
	flattened = flatten(ast);
	flattened->repr(flattened, repr_token);
	ft_printf("\n");
}

static void	test_flatten(t_gc *gc)
{
	t_parser	*parser;

	parser = init_parser(gc);

	ft_printf("==========TEST_FLATTEN==========\n\n");

	test_flatten_case("ls -l | cat -e", parser, gc);
	test_flatten_case("a | b | c | d", parser, gc);
	test_flatten_case("a|b|c", parser, gc);

	ft_printf("==========ALL TESTS PASSED==========\n\n");
}


int main(void)
{
	t_gc	*gc;

	gc = init_gc();
	test_t_token(gc);
	test_parser_is_valid_cmd(gc);
	test_parser_tokenize(gc);
	test_parser_parse(gc);
	test_flatten(gc);
	test_exec(gc);
	gc->clean(gc);
}

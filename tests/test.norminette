#include <assert.h>
#include "datastructures.h"
#include "gc_libft.h"
#include "minishell.h"

static void	repr_str(void *value)
{
	ft_printf("\"%s\"", (char *)value);
}

static void	test_parser_tokenize(t_gc *gc)
{
	t_parser	*parser;
	t_darray	*cmds;
	char		*s;

	ft_printf("==========TEST_PARSER_TOKENIZE==========\n");
	parser = init_parser(gc);

	// empty string
	s = "";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// single pipe
	s = "ls -l | grep -la";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// pipe without spaces
	s = "ls -l|grep -la";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// pipe + and
	s = "ls -l | grep -la && cat -e";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// and without spaces
	s = "ls -l | grep -la&&cat -e";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// pipe + and + or
	s = "ls -l | grep -la && cat -e || ls -la";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// or without spaces
	s = "ls -l | grep -la&&cat -e|| ls -la";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// operators inside double quotes (should not tokenize)
	s = "ls -l | \"grep -la&&cat -e\"|| ls -la";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// operators inside single quotes (should not tokenize)
	s = "echo '|| && |' | cat";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// parentheses
	s = "(echo hello && echo world)";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// nested parentheses
	s = "(echo hello && (echo world || echo foo))";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// parentheses without spaces
	s = "(ls -l)&&(echo hello)";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// parentheses inside quotes (should not tokenize)
	s = "echo \"(hello)\" | cat";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// simple command, no operators
	s = "echo hello world";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// multiple pipes
	s = "cat file | grep foo | wc -l";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	// all operators combined
	s = "(ls | grep foo) && echo yes || echo no";
	ft_printf("Tokenizing %s\n", s);
	cmds = parser->tokenize(s, gc);
	cmds->repr(cmds, repr_str);
	ft_printf("\n");

	ft_printf("==========ALL TESTS PASSED==========\n\n");
}

static void test_parser_is_valid_cmd(t_gc *gc)
{
	t_parser	*parser;
	char		*s;

	ft_printf("==========TEST_PARSER_IS_VALID_CMD==========\n");
	parser = init_parser(gc);

	// basic
	s = "";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "echo hello";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);

	// single quotes
	s = "'hello'";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "''";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "'";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "'hello";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);

	// double quotes
	s = "\"hello\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "\"\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "\"hello";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);

	// mixed quotes
	s = "\"'\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "'\"'";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "\"''\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "'\"\"'";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "\"'";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "'\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "\"'\"''";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "'\"'\"'\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);

	// parentheses
	s = "()";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "(())";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "()()";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "((()))";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "(";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = ")";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "((";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "))";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = ")(";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "(()";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "())";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);

	// parentheses inside quotes (should be ignored)
	s = "'()'";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "'('";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "')'";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "\"()\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "\"(\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "\")\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);

	// quotes inside parentheses
	s = "('hello')";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "(\"hello\")";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);

	// combined edge cases
	s = "''()()";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "(\")\"";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "(')'";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "\"(\")";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "'(')";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);

	// realistic commands
	s = "(echo hello && echo world)";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "(echo hello && (echo world))";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == true);
	s = "echo 'unclosed";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);
	s = "echo \"unclosed";
	ft_printf("Testing %s\n", s);
	assert(parser->is_valid_cmd(s) == false);

	ft_printf("==========ALL TESTS PASSED==========\n\n");
}

int main(void)
{
	t_gc	*gc;

	gc = init_gc();
	test_parser_is_valid_cmd(gc);
	test_parser_tokenize(gc);
	gc->clean(gc);
}
